# ═══════════════════════════════════════════════════════════
# Real Pan API - Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────
# SERVIDOR
# ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
API_URL=https://api.realpan.jp

# ─────────────────────────────────────────────────────────
# BANCO DE DADOS (PostgreSQL)
# ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://realpan:SUA_SENHA_AQUI@localhost:5432/realpan_db"

# ─────────────────────────────────────────────────────────
# JWT (Autenticação)
# ─────────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
JWT_SECRET=TROCAR_POR_STRING_ALEATORIA_FORTE
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────
# STRIPE (Pagamentos)
# ─────────────────────────────────────────────────────────
# Obter em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret
# Obter em: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────────────────
# UPLOADS
# ─────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ─────────────────────────────────────────────────────────
# CORS (Permitir frontend)
# ─────────────────────────────────────────────────────────
CORS_ORIGIN=https://realpan.co.jp,https://www.realpan.co.jp

# ─────────────────────────────────────────────────────────
# OPCIONAL: Email (futuro)
# ─────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-app
# EMAIL_FROM=noreply@realpan.jp
